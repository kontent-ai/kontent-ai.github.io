{
    "version": "0.2",
    "language": "en",
    "words": [
        "aspnetcore",
        "cheatsheet",
        "Codecov",
        "codenames",
        "CODEOWNERS",
        "Fastly",
        "jumpstart",
        "kontent",
        "npmjs",
        "Packagist",
        "premade",
        "Presales",
        "Rubygems",
        "sandboxed",
        "subpages"
    ],
    "ignoreWords": [
        "DDTHH"
    ],
    "ignoreRegExpList": [
        "\\`([^\\`].*?)\\`", // inline code blocks. h/t https://stackoverflow.com/questions/41274241/how-to-capture-inline-markdown-code-but-not-a-markdown-code-fence-with-regex
        "/^\\s*```[\\s\\S]*?^\\s*```/gm", // Markdown code blocks. https://github.com/streetsidesoftware/vscode-spell-checker/issues/202#issuecomment-377477473
        "^---[\\s\\S]*?---$", // YAML front-matter
        "^https?:\\/\\/(?:www\\.)?[-a-zA-Z0-9@:%._\\+~#=]{1,256}\\.[a-zA-Z0-9()]{1,6}\\b(?:[-a-zA-Z0-9()@:%_\\+.~#?&\\/=]*)$" //URL
    ]
}
